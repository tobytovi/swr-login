{
  "name": "@swr-login/core",
  "version": "0.3.0",
  "description": "Core logic for swr-login: state machine, token management, plugin system, event emitter",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": ["swr", "login", "auth", "react", "hook", "plugin"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tobytovi/swr-login",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tobytovi/swr-login#readme",
  "bugs": "https://github.com/tobytovi/swr-login/issues",
  "publishConfig": {
    "access": "public"
  }
}
