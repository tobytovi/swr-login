{
  "name": "@swr-login/react",
  "version": "0.6.0",
  "description": "React bindings for swr-login: Provider, Hooks, and AuthGuard component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "swr": ">=2.0.0"
  },
  "dependencies": {
    "@swr-login/core": "workspace:*"
  },
  "keywords": ["swr", "login", "auth", "react", "hook"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tobytovi/swr-login",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/tobytovi/swr-login#readme",
  "bugs": "https://github.com/tobytovi/swr-login/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
